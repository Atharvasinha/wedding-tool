# Wedding Tool · Environment Variables
# Copy this to .env.local and fill in real values. Never commit .env.local.

# ============================================================
# DATABASE · Vercel Postgres
# ============================================================
# From Vercel Postgres. Get this from the Vercel dashboard:
# Storage tab > Postgres > .env.local. Both URLs come from there.
DATABASE_URL="postgresql://user:pass@host/db?sslmode=require"
DIRECT_URL="postgresql://user:pass@host/db?sslmode=require"

# ============================================================
# AUTH · magic-link via Resend
# ============================================================
# Resend API key for sending magic-link emails.
# Sign up at resend.com, verify celesia.atharva@gmail.com as sender.
RESEND_API_KEY="re_..."
EMAIL_FROM="celesia.atharva@gmail.com"

# 32+ char random string for signing session tokens.
# Generate: openssl rand -hex 32
AUTH_SECRET=""

# ============================================================
# GMAIL · OAuth2 read-only access to celesia.atharva@gmail.com
# ============================================================
# Get these from Google Cloud Console > APIs & Services > Credentials.
# Create OAuth2 Client ID, type Web Application.
# Authorized redirect URI: https://your-vercel-domain.com/api/auth/gmail/callback
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
GOOGLE_REDIRECT_URI="https://your-domain.com/api/auth/gmail/callback"

# The Gmail account being polled. Hardcoded for this single-wedding tool.
GMAIL_ACCOUNT="celesia.atharva@gmail.com"

# Stored refresh token after first auth. Set this once via the auth flow,
# then the cron job uses it forever.
GMAIL_REFRESH_TOKEN=""

# ============================================================
# GOOGLE SHEETS · the auditable mirror
# ============================================================
# Use the same Google Cloud project. Enable the Sheets API.
# Create a Service Account, download the JSON key.
# Paste the full JSON (single line) here.
GOOGLE_SERVICE_ACCOUNT_KEY="{...}"

# The Sheet ID where data is mirrored. Create the Sheet manually,
# share it with the service account email as Editor, paste its ID here.
# Sheet ID is the long string in the URL between /d/ and /edit.
SHEETS_MIRROR_ID=""

# ============================================================
# VERCEL CRON
# ============================================================
# Optional secret to gate the cron endpoints. Generate with openssl rand -hex 32.
CRON_SECRET=""

# ============================================================
# APP CONFIG
# ============================================================
# The locked wedding date. Used everywhere for countdowns and "wedding-relative" payment scheduling.
WEDDING_DATE="2027-12-11"

# Locked budget baseline in cents. $142,682.00 = 14268200
BUDGET_BASELINE_CENTS="14268200"

# Tolerance band for budget variance warning. 0.05 = ±5%.
BUDGET_TOLERANCE="0.05"
