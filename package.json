{
  "name": "wedding-tool",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "prisma generate && prisma migrate deploy && next build",
    "start": "next start",
    "postinstall": "prisma generate",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "seed": "tsx scripts/seed.ts",
    "db:migrate": "prisma migrate dev",
    "db:studio": "prisma studio",
    "db:generate": "prisma generate",
    "db:up": "powershell -NoProfile -Command \"& $env:USERPROFILE\\.wedding-pg\\bin\\pg_ctl.exe -D $env:USERPROFILE\\.wedding-pg\\data -l $env:USERPROFILE\\.wedding-pg\\postgres.log -o '-p 5432 -h localhost' -w start\"",
    "db:down": "powershell -NoProfile -Command \"& $env:USERPROFILE\\.wedding-pg\\bin\\pg_ctl.exe -D $env:USERPROFILE\\.wedding-pg\\data stop\"",
    "db:status": "powershell -NoProfile -Command \"& $env:USERPROFILE\\.wedding-pg\\bin\\pg_ctl.exe -D $env:USERPROFILE\\.wedding-pg\\data status\""
  },
  "prisma": {
    "seed": "tsx scripts/seed.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.98.0",
    "@prisma/client": "^5.22.0",
    "@radix-ui/react-dialog": "^1.1.2",
    "@radix-ui/react-popover": "^1.1.2",
    "@radix-ui/react-slot": "^1.1.0",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "googleapis": "^172.0.0",
    "jose": "^6.2.3",
    "lucide-react": "^0.454.0",
    "next": "^14.2.16",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "resend": "^6.12.3",
    "tailwind-merge": "^2.5.4",
    "xlsx": "^0.18.5",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.9.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "autoprefixer": "^10.4.20",
    "dotenv": "^17.4.2",
    "eslint": "^8.57.1",
    "eslint-config-next": "^14.2.16",
    "postcss": "^8.4.49",
    "prisma": "^5.22.0",
    "tailwindcss": "^3.4.14",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3"
  }
}
